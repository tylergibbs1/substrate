<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- V8 / Chromium need JIT + unsigned executable memory under hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- The app spawns the bundled server with ELECTRON_RUN_AS_NODE, so it must be
       allowed to set DYLD/Node env vars on the child under hardened runtime. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- Loading the bundled server (.mjs) via the Electron helper. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
