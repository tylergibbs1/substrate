{
  "name": "@substrate/desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Electron shell that bundles the Substrate server and web editor.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.3.0"
  },
  "build": {
    "appId": "com.substrate.app",
    "productName": "Substrate",
    "files": ["main.js", "preload.cjs", "build/**"],
    "extraResources": [
      { "from": "../server/dist/server.mjs", "to": "server/server.mjs" },
      { "from": "../web/dist", "to": "web" },
      { "from": "../server/assets/demo", "to": "demo" }
    ],
    "directories": { "buildResources": "build" },
    "publish": { "provider": "github", "owner": "tylergibbs1", "repo": "substrate" },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": { "target": "AppImage", "icon": "build/icon.png", "category": "Graphics" },
    "win": { "target": "nsis", "icon": "build/icon.png" }
  }
}
